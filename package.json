{
  "name": "@versa-stack/v-craft",
  "license": "MIT",
  "description": "Vue3 UI builder kit.",
  "version": "0.1.0-alpha.2",
  "scripts": {
    "build-raw": "vite build",
    "build": "rimraf dist && vite build",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:serve": "vitepress serve docs",
    "watch:build": "nodemon -e ts -e vue -x \"npm run build\"",
    "docs:preview": "vitepress preview docs",
    "test": "vitest",
    "test:coverage": "vitest run --coverage  --reporter=junit --outputFile=test-report.junit.xml"
  },
  "peerDependencies": {
    "@formkit/vue": "^1.6.7",
    "jsonpath": "^1.1.1",
    "lodash-es": "^4.17.21",
    "pinia": "^2.0||^3.0",
    "uuid": "^10.0.0||^11.0.0",
    "vue": "^3.5"
  },
  "devDependencies": {
    "@algolia/client-search": "^5.8.1",
    "@apollo/client": "^3.11.8",
    "@formkit/vue": "^1.6.7",
    "@pinia/testing": "^1.0.0",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/git": "^10.0.1",
    "@tailwindcss/postcss": "^4.0.14",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^22.7.6",
    "@vitejs/plugin-vue": "^5.1.4",
    "@vitest/coverage-v8": "^3.0.8",
    "@vue/apollo-composable": "^4.2.1",
    "@vue/test-utils": "^2.4.6",
    "autoprefixer": "^10.4.20",
    "conventional-changelog-conventionalcommits": "^8.0.0",
    "happy-dom": "^17.4.4",
    "jsonpath": "^1.1.1",
    "lodash-es": "^4.17.21",
    "nodemon": "^3.1.7",
    "pinia": "^2.0||^3.0",
    "postcss": "^8.4.47",
    "rimraf": "^6.0.1",
    "sass": "^1.80.1",
    "semantic-release": "^24.2.0",
    "tailwindcss": "^4.0.14",
    "ts-jest": "^29.0.5",
    "typescript": "^5.6.3",
    "uuid": "^11.0.0",
    "vite": "^6.2.2",
    "vite-plugin-dts": "^4.2.4",
    "vitepress": "^1.4.1",
    "vitest": "^3.0.8",
    "vue": "^3.5",
    "vue-tsc": "^2.1.6"
  },
  "files": [
    "dist"
  ],
  "types": "./dist/types/index.d.ts",
  "module": "./dist/v-craft.es.js",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/v-craft.es.js"
    },
    "./dist/style.css": "./dist/style.css"
  }
}
